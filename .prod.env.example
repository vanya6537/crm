# Render production environment template
# Do NOT commit real secrets. Copy to Render Environment tab instead.

APP_NAME="CRM"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app-name.onrender.com
APP_KEY=base64:YLuS7xx5zZTd8UcO2bzLoxChDnF4succSw5+pvabD2g=

# Locale
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru

# Trust Render proxy headers (needed for correct https detection)
TRUSTED_PROXIES=*

# Run migrations on container start (recommended on Render)
RUN_MIGRATIONS=true

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database (SQLite)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# Optional: Render Postgres
# DB_CONNECTION=pgsql
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# If you don't use DATABASE_URL, set these instead:
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# Caching / queues (Render-friendly defaults)
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Encryption/cookies
SESSION_ENCRYPT=false
SESSION_LIFETIME=120

# Vite/Inertia
VITE_APP_NAME="${APP_NAME}"
